    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "googleapis": "^173.0.0",
    "html2canvas": "^1.4.1",
    "jsbarcode": "^3.12.3",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "multer": "^2.2.0",
    "nodemailer": "^6.10.1",
    "pg": "^8.21.0",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-router-dom": "^7.18.1",
