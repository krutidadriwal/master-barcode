# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# SUPABASE_URL: Optional. Base URL of your Supabase Cloud project (e.g., https://your-proj.supabase.co).
# If omitted, the BFF runs in a local persistent high-performance sandbox loaded with sample products.
SUPABASE_URL=""

# SUPABASE_ANON_KEY: Optional. Public/anonymous API key of your Supabase project.
SUPABASE_ANON_KEY=""

# SUPABASE_SERVICE_KEY: Optional but recommended for server-side (Vercel) deployments.
# Service role key bypasses Row Level Security for mutations (scan-line, sync, writeback).
# Find it in: Supabase Dashboard → Project Settings → API → service_role key.
# Never expose this in the frontend — server/Vercel env only.
SUPABASE_SERVICE_KEY=""

# PostgreSQL Direct Connection Details (Optional alternatives to REST SDK client)
# If provided, the system will use a direct PostgreSQL pool query driver to connect to your Supabase postgres instance.
# Example: postgresql://postgres:[YOUR_PASSWORD]@db.qfksxkrhxldioubndndh.supabase.co:5432/postgres
DATABASE_URL=""

# Or define individual PostgreSQL connection variables:
PGHOST="db.qfksxkrhxldioubndndh.supabase.co"
PGPORT=5432
PGDATABASE="postgres"
PGUSER="postgres"
PGPASSWORD="YOUR_SUPABASE_DATABASE_PASSWORD"

# SMTP Email Configuration (for duplicate EAN escalation emails)
# Required to enable automatic email alerts when duplicate EANUPCs are detected.
# Supports any SMTP provider (Gmail, Outlook, custom mail server, etc.)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER="your-email@example.com"
SMTP_PASS="your-smtp-password-or-app-password"

# App Script Product Master Source
# Set APP_SCRIPT_FOR_BARCODE=true to sync product data from the EE Product Master
# Google Sheet (via MASTER_BARCODE_SCRIPTS_URL) into a local barcode_product_master
# Supabase table, and use THAT table for all barcode lookups.
# Set to false (default) to use the central DB (EasyEcomProductMaster) as before.
APP_SCRIPT_FOR_BARCODE=false
# Mirror of APP_SCRIPT_FOR_BARCODE — exposes the flag to the Vite frontend so the
# Sync Product Master button is shown only when Apps Script mode is active.
VITE_APP_SCRIPT_FOR_BARCODE=false
# Base URL of the Google Apps Script deployment (without ?action=...).
# The backend appends ?action=barcodeProductMaster automatically.
MASTER_BARCODE_SCRIPTS_URL=""

# App Script for Shipment Batches (used by Shipment Barcode module)
APP_SCRIPTS_URL=""

# App Script for the Download Receiving Sheet (used by Shipment Barcode module's
# Refresh button). Points to a Web App deployment bound to a DIFFERENT spreadsheet
# ('Inventory') than APP_SCRIPTS_URL — see CodeScript/Inventory/ReceivingSheet_*.gs.
# Only used when APP_SCRIPT_FOR_BARCODE=true; the central DB flow for this has not
# been built yet, so sync/lines requests return a clear error when the flag is off.
INVENTORY_SCRIPTS_URL=""

